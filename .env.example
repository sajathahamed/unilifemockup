# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: For server-side operations with service role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Postgres URI (Settings → Database) — required only for npm run db:apply:student-timetable / local SQL tools
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Google Maps / Places (Trip Planner, Distance Matrix, Geocoding)
# Enable: Maps JavaScript API, Places API (New), Distance Matrix API, Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google OAuth (configured in Supabase Dashboard)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Dialog Rich Communication SMS (https://richcommunication.dialog.lk/api/sms/send) ──
# Same as PHP POS Marketing Send_msg(): USER, DIGEST=md5(password), CREATED=Asia/Colombo Y-m-d\TH:i:s,
# JSON body messages[].{ clientRef, number, mask, text, campaignName }.
#
# Sender mask — optional; defaults to BMF (POS marketing). First non-empty wins:
# DIALOG_SMS_MASK, DIALOG_MARKETING_MASK, DIALOG_POS_MASK
#
# Defaults aligned with POS marketing (override if your account differs):
DIALOG_SMS_USER=Upview
DIALOG_SMS_PASSWORD=your_dialog_api_password
# DIALOG_SMS_CLIENT_REF=RPOSbyUpview
# DIALOG_SMS_CAMPAIGN_NAME=restsaaspos
#
# Timetable cron still sends campaignName=timetable_reminder explicitly.
# Student test SMS uses default clientRef prefix + restsaaspos unless you override env above.
#
# After editing .env.local, restart: npm run dev
